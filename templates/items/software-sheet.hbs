<form class="{{cssClass}}" autocomplete="off">
  <header class="sheet-header hh-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="header-fields">
      <input name="name" type="text" value="{{item.name}}" placeholder="{{localize 'MOSHHH.Name'}}" />
      <div class="hh-subtitle">{{localize "MOSHHH.HackingSoftware"}}</div>
    </div>
  </header>
  <div class="hh-grid two">
    <label>{{localize "MOSHHH.Cost"}} <input name="system.cost" type="number" value="{{item.system.cost}}" /></label>
    <label>{{localize "MOSHHH.Quantity"}} <input name="system.quantity" type="number" value="{{item.system.quantity}}" /></label>
    <label>{{localize "MOSHHH.RequiredSlots"}} <input name="hh.slots" type="number" value="{{hh.slots}}" /></label>
    <label>{{localize "MOSHHH.Duration"}} <input name="hh.activation.duration" type="text" value="{{hh.activation.duration}}" /></label>
    <label>{{localize "MOSHHH.Target"}} <input name="hh.activation.target" type="text" value="{{hh.activation.target}}" /></label>
    <label>{{localize "MOSHHH.AssociatedRoll"}} <input name="hh.activation.roll" type="text" value="{{hh.activation.roll}}" /></label>
    <label class="hh-wide"><input type="checkbox" name="hh.singleUse" {{#if hh.singleUse}}checked{{/if}} /> {{localize "MOSHHH.SingleUse"}}</label>
  </div>
  <label class="hh-description">{{localize "MOSHHH.Description"}}
    <textarea name="system.description" rows="5">{{item.system.description}}</textarea>
  </label>
  <footer class="sheet-footer flexrow"><button type="submit"><i class="fas fa-save"></i> {{localize "MOSHHH.Save"}}</button></footer>
</form>
